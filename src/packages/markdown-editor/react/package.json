{
  "name": "@f-wiki/markdown-editor-react",
  "version": "0.1.0",
  "description": "React adapter for @f-wiki/markdown-editor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@f-wiki/markdown-editor": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-dts": "^4"
  }
